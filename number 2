#include <stdio.h>

int можно_разделить(int массив[], int размер) {
    int сумма = 0;
    for (int i = 0; i < размер; i++) {
        сумма = сумма + массив[i];
    }
    
    // Если сумма нечетная - разделить нельзя
    if (сумма % 2 != 0) {
        return 0;
    }
    
    int половина = сумма / 2;
    int сумма_левой = 0;
    
    for (int i = 0; i < размер - 1; i++) {
        сумма_левой = сумма_левой + массив[i];
        if (сумма_левой == половина) {
            return 1; 
        }
    }
    
    return 0; 
}

int main() {
    int числа[] = {1, 2, 3, 4, 5, 5};
    int сколько = 6;
    
    if (можно_разделить(числа, сколько) == 1) {
        printf("можно разделить!\n");
    } else {
        printf("нельзя разделить\n");
    }
    
    return 0;
}
